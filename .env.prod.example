# Production environment variables for docker-compose.prod.yml
# Copy this file to .env.prod and fill in the values:
#   cp .env.prod.example .env.prod
#
# IMPORTANT: Never commit .env.prod to source control.
# This example file is safe to commit — it contains no real secrets.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Database username
POSTGRES_USER=ifemuser

# Database password (plain text — used directly by the Postgres container)
POSTGRES_PASSWORD=change_me_secure_password

# URL-encoded version of POSTGRES_PASSWORD — used in DATABASE_URL connection string.
# Special characters must be percent-encoded, e.g. "@" → "%40", "#" → "%23".
# If your password contains no special characters, this is the same as POSTGRES_PASSWORD.
POSTGRES_PASSWORD_ENCODED=change_me_secure_password

# Database name
POSTGRES_DB=ifem_radar

# ─── Backend ──────────────────────────────────────────────────────────────────
# Secret key used to sign and verify JWT tokens.
# Generate a strong random value, e.g.:
#   openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret

# Log level for the Rust backend (optional — defaults to "info")
# RUST_LOG=info
